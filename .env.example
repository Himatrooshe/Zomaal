NODE_ENV=development
PORT=3000
SWAGGER_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
WEBHOOK_DEBUG_ENABLED=false

DATABASE_URL="postgresql://postgres:password@localhost:5434/zomaal"

JWT_SECRET=replace-with-a-random-64-character-jwt-secret

REDIS_HOST=localhost
REDIS_PORT=6380

# Twilio
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_SERVICE_SID=replace-with-twilio-service-sid

# Sendit.ma
SENDIT_API_BASE_URL=https://app.sendit.ma/api/v1
SENDIT_PUBLIC_KEY=replace-with-sendit-public-key
SENDIT_SECRET_KEY=replace-with-sendit-secret-key
SENDIT_TOKEN_TTL_SECONDS=3300

# QuickLivraison
QUICKLIVRAISON_API_BASE_URL=https://clients.quicklivraison.ma/api
QUICKLIVRAISON_API_KEY=replace-with-quicklivraison-api-key
QUICKLIVRAISON_WEBHOOK_SECRET=replace-with-quicklivraison-webhook-secret

# ForceLog.ma
FORCELOG_API_BASE_URL=https://api.forcelog.ma/customer
FORCELOG_HEALTH_BASE_URL=https://api.forcelog.ma
FORCELOG_API_KEY=replace-with-forcelog-api-key

# OzoneExpress.ma
OZONEEXPRESS_API_BASE_URL=https://api.ozonexpress.ma
OZONEEXPRESS_CLIENT_BASE_URL=https://client.ozoneexpress.ma
OZONEEXPRESS_CUSTOMER_ID=replace-with-ozoneexpress-customer-id
OZONEEXPRESS_API_KEY=replace-with-ozoneexpress-api-key
