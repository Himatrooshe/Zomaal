// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(uuid())
  phone              String   @unique
  isPhoneVerified    Boolean  @default(true)
  onboardingComplete Boolean  @default(false)
  passwordHash       String?
  hashedRefreshToken String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  store                    Store?
  senditConnection         SenditConnection?
  quickLivraisonConnection QuickLivraisonConnection?
  forceLogConnection       ForceLogConnection?
  ozoneExpressConnection   OzoneExpressConnection?
}

model QuickLivraisonConnection {
  id              String   @id @default(uuid())
  encryptedApiKey String
  keyType         String
  connectedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ForceLogConnection {
  id              String   @id @default(uuid())
  encryptedApiKey String
  connectedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OzoneExpressConnection {
  id                  String   @id @default(uuid())
  encryptedCustomerId String
  encryptedApiKey     String
  connectedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SenditConnection {
  id                 String   @id @default(uuid())
  encryptedPublicKey String
  encryptedSecretKey String
  accountName        String?
  connectedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Store {
  id           String   @id @default(uuid())
  ownerName    String
  businessName String
  address      String
  city         String
  country      String
  logoUrl      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}
